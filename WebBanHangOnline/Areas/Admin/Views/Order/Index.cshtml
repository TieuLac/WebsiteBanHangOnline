@model PagedList.IPagedList<WebBanHangOnline.Models.EF.Order>
@using PagedList.Mvc;
@{
    ViewBag.Title = "Danh sách đơn hàng";
}

<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.32/dist/sweetalert2.min.css" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.32/dist/sweetalert2.all.min.js"></script>

<style>
    .status-badge {
        display: inline-block;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.9em;
        font-weight: bold;
        text-align: center;
        white-space: nowrap;
    }

    .status-paid {
        background-color: #e9ecef;
        color: cadetblue;
    }

    .status-unpaid {
        background-color: #e9ecef;
        color: blueviolet;
    }

    .status-cancelled {
        background-color: #e9ecef;
        color: red;
    }

    .status-completed {
        background-color: #e9ecef;
        color: forestgreen;
    }

    .status-preparing {
        background-color: #e9ecef;
        color: palevioletred;
    }

    .status-delivering {
        background-color: #e9ecef;
        color: goldenrod;
    }

    .status-unsuccessful {
        background-color: #e9ecef;
        color: orange;
    }

</style>

@section naviheader{
    <!-- Left navbar links -->
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin" class="nav-link">Trang chủ</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin/order" class="nav-link">Danh sách đơn hàng</a>
        </li>
    </ul>
}

<!-- Main content -->
<section class="content">

    <!-- Default box -->
    <div class="card" style="margin-top:20px">
        <div class="card-header">
            <h3 class="card-title">Danh sách đơn hàng</h3>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-6">
                    @using (Html.BeginForm("index", "Order", FormMethod.Get, new { }))
                    {
                        <div class="input-group input-group-sm">
                            @*@Html.TextBox("Searchtext")*@
                            @Html.TextBox("Searchtext", null, new { @class = "form-control", placeholder = "Nhập mã đơn hàng, tên hoặc số điện thoại..." })
                            @*<input type="text" name="searchtext" class="form-control">*@
                            <span class="input-group-append">
                                <button type="submit" class="btn btn-primary">Tìm kiếm</button>
                            </span>
                        </div>
                    }
                </div>
            </div>
            <table class="table table-bordered" style="margin-top: 20px">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Mã đơn hàng</th>
                        <th>Tên Khách hàng</th>
                        <th>Phone</th>
                        <th>Tiền</th>
                        <th>Phương thức thanh toán</th>
                        <th>Thanh toán</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        var i = ((ViewBag.Page - 1) * ViewBag.PageSize) + 1;
                        var approvedOrders = Model.Where(x => x.IsApprove == true && (x.OrderStatus != 3 || x.OrderStatus != 4 || x.OrderStatus != 7));
                        foreach (var item in approvedOrders)
                        {
                            <tr>
                                <td>@i</td>
                                <td>@item.Code</td>
                                <td>@item.CustomerName</td>
                                <td>@item.Phone</td>
                                <td>@WebBanHangOnline.Common.Common.FormatNumber(item.TotalAmount, 0)</td>
                                <td>@(item.TypePayment==1?"COD":"Chuyển khoản")</td>
                                <td>
                                    @if (item.Status == 1)
                                    {
                                        <span class="status-badge status-unpaid"><b>Chưa thanh toán</b></span>
                                    }
                                    @if (item.Status == 2)
                                    {
                                        <span class="status-badge status-paid"><b>Đã thanh toán</b></span>
                                    }
                                </td>
                                <td>
                                    @if (item.OrderStatus == 1)
                                    {
                                        <span class="status-badge status-unpaid"><b>Chưa thanh toán</b></span>
                                    }
                                    @if (item.OrderStatus == 2)
                                    {
                                        <span class="status-badge status-paid"><b>Đã thanh toán</b></span>
                                    }
                                    @if (item.OrderStatus == 3)
                                    {
                                        <span class="status-badge status-completed"><b>Hoàn thành</b></span>
                                    }
                                    @if (item.OrderStatus == 4)
                                    {
                                        <span class="status-badge status-cancelled"><b>Hủy</b></span>
                                    }
                                    @if (item.OrderStatus == 5)
                                    {
                                        <span class="status-badge status-delivering"><b>Đang giao</b></span>
                                    }
                                    @if (item.OrderStatus == 6)
                                    {
                                        <span class="status-badge status-preparing"><b>Đang chuẩn bị hàng</b></span>
                                    }
                                    @if (item.OrderStatus == 7)
                                    {
                                        <span class="status-badge status-unsuccessful"><b>Giao hàng không thành công</b></span>
                                    }
                                </td>
                                <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <a href="/admin/order/view/@item.Id" class="btn btn-sm btn-success">Xem</a>
                                    <a href="#" class="btn btn-sm btn-danger btnCapNhat" data-id="@item.Id">Cập nhật</a>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                </tbody>
            </table>

            <div class="row">
                <div class="col-6"></div>
                <div class="col-6" style="text-align:right;">
                    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }))
                </div>
            </div>
        </div>
        <!-- /.card-body -->
        <div class="card-footer">

        </div>
        <!-- /.card-footer-->
    </div>
    <!-- /.card -->

</section>
<!-- /.content -->

<div class="modal fade" id="modal-default">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">Cập nhật trạng thái</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="txtOrderId" value="0" />
                <div class="form-group">
                    <label>Trạng thái đơn hàng</label>
                    <select class="form-control" id="ddTrangThai">
                        @*<option value="2">
                            Đã thanh toán
                        </option>*@
                        <option value="6">
                            Đang chuẩn bị hàng
                        </option>
                        <option value="5">
                            Đang giao
                        </option>
                        <option value="3">
                            Hoàn thành
                        </option>
                        <option value="7">
                            Giao hàng không thành công
                        </option>
                        <option value="4">
                            Hủy
                        </option>
                    </select>
                </div>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-default" data-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary" id="btnLuu">Lưu</button>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!-- /.modal-dialog -->
</div>
<!-- /.modal -->

@section scripts{
    <script>
        $(document).ready(function () {
            $('body').on('click', '.btnCapNhat', function () {
                var id = $(this).data("id");
                $('#txtOrderId').val(id);
                $('#modal-default').modal('show');
            });

            $('body').on('click', '#btnLuu', function () {
                var id = $('#txtOrderId').val();
                var tt = $('#ddTrangThai').val();

                Swal.fire({
                    title: 'Xác nhận',
                    text: "Bạn có chắc chắn muốn cập nhật trạng thái đơn hàng?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Đồng ý',
                    cancelButtonText: 'Hủy'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            //url: '/admin/order/UpdateTT',
                            url: '@Url.Action("UpdateTT", "Order")',
                            type: 'POST',
                            data: { id: id, trangthai: tt },
                            success: function (res) {
                                if (res.Success) {
                                    Swal.fire({
                                        title: 'Thành công!',
                                        text: 'Cập nhật trạng thái đơn hàng thành công',
                                        icon: 'success',
                                        confirmButtonText: 'OK'
                                    }).then((result) => {
                                        if (result.isConfirmed) {
                                            location.reload();
                                        }
                                    });
                                }
                                else {
                                    Swal.fire({
                                        icon: 'error',
                                        title: 'Không thể cập nhật đơn hàng',
                                        text: res.message
                                    });
                                    $('#modal-default').modal('hide');
                                }
                            }
                        });
                    }
                });
            });
        });</script>
}