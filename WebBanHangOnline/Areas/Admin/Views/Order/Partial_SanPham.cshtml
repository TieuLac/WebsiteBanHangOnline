@model IEnumerable<WebBanHangOnline.Models.EF.OrderDetail>
@if (Model != null && Model.Any())
{
    int i = 1;
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>#</th>
                <th>Ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Size</th>
                <th>Màu sắc</th>
                <th>Giá</th>
                <th>Số lượng</th>
                <th>Thành tiền</th>
            </tr>

        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@i</td>
                    <td><img style="width:100px; height:100px; object-fit: contain" src="@item.ProductInventory.Product.ProductImage.FirstOrDefault(x=>x.IsDefault).Image"/></td>
                    <td>@item.ProductInventory.Product.Title</td>
                    <td>@item.ProductInventory.Size.SizeName</td>
                    <td>@item.ProductInventory.Color.ColorName</td>
                    <td>@WebBanHangOnline.Common.Common.FormatNumber(@item.Price)</td>
                    <td>@item.Quantity</td>
                    <td>@WebBanHangOnline.Common.Common.FormatNumber((item.Price * item.Quantity), 0)</td>
                </tr>
                i++;
            }
        </tbody>
    </table>
}

