@model WebBanHangOnline.Models.EF.ProductInventory
@{
    ViewBag.Title = "Thêm mới biến thể sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

@section naviheader{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin" class="nav-link">Trang chủ</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="/admin/productinventory" class="nav-link">Biến thể sản phẩm</a>
        </li>
        <li class="nav-item d-none d-sm-inline-block">
            <a href="#" class="nav-link">Thêm mới</a>
        </li>
    </ul>
}

<!-- Content Header (Page header) -->
<section class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Thêm mới biến thể sản phẩm</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="#">Biến thể sản phẩm</a></li>
                    <li class="breadcrumb-item active">Thêm mới</li>
                </ol>
            </div>
        </div>
    </div><!-- /.container-fluid -->
</section>

<!-- Main content -->
<section class="content">

    <!-- Default box -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Thông tin thêm mới biến thể sản phẩm</h3>
        </div>
        <div class="card-body">
            <div class="bs-stepper-content">
                @using (Html.BeginForm("Add", "ProductInventory", FormMethod.Post, new { }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true)
                    <div id="logins-part" class="content" role="tabpanel" aria-labelledby="logins-part-trigger">
                        <div class="form-group">
                            <label for="exampleInputEmail1">Sản phẩm</label>
                            @Html.DropDownListFor(x => x.ProductId, ViewBag.Product as SelectList, "-Chọn sản phẩm-", new { @class = "form-control", @placeholder = "Tên sản phẩm" })
                            @Html.ValidationMessageFor(x => x.ProductId, null, new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            <label for="exampleInputEmail1">Kích thước</label>
                            @Html.DropDownListFor(x => x.SizeId, ViewBag.ProductSize as SelectList, "-Chọn kích thước sản phẩm-", new { @class = "form-control", @placeholder = "Kích thước sản phẩm" })
                            @Html.ValidationMessageFor(x => x.SizeId, null, new { @class = "text-danger" })
                        </div>

                        <div class="form-group">
                            <label for="exampleInputEmail1">Màu sắc</label>
                            @Html.DropDownListFor(x => x.ColorId, ViewBag.ProductColor as SelectList, "-Chọn màu sắc sản phẩm-", new { @class = "form-control", @placeholder = "Màu sắc sản phẩm" })
                            @Html.ValidationMessageFor(x => x.ColorId, null, new { @class = "text-danger" })
                        </div>

                        <div class="row">
                            <div class="col-3">
                                <div class="form-group">
                                    <label for="exampleInputEmail1">Số lượng sản phẩm</label>
                                    <input type="text" name="demoQuantity" id="demoQuantity" class="form-control autoNum" placeholder="Số lượng sản phẩm" data-a-dec="," data-a-sep=".">
                                    @Html.HiddenFor(x => x.Quantity, new { @class = "form-control", @Value = "1" })
                                    @Html.ValidationMessageFor(x => x.Quantity, null, new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="form-group">
                                    <label for="exampleInputEmail1">Giá sản phẩm</label>
                                    <input type="text" name="demoPrice" id="demoPrice" class="form-control autoNum" placeholder="Giá sản phẩm" data-a-dec="," data-a-sep=".">
                                    @Html.HiddenFor(x => x.Price, new { @class = "", @placeholder = "Giá" })
                                    @Html.ValidationMessageFor(x => x.Price, null, new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="form-group">
                                    <label for="exampleInputEmail1">Giá khuyến mãi</label>
                                    <input type="text" name="demoPriceSale" id="demoPriceSale" class="form-control autoNum" placeholder="Giá khuyến mãi" data-a-dec="," data-a-sep=".">
                                    @Html.HiddenFor(x => x.PriceSale, new { @class = "", @placeholder = "Giá khuyến mãi" })
                                    @Html.ValidationMessageFor(x => x.PriceSale, null, new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="form-group">
                                    <label for="exampleInputEmail1">Giá nhập</label>
                                    <input type="text" name="demoOriginalPrice" id="demoOriginalPrice" class="form-control autoNum" placeholder="Giá nhập" data-a-dec="," data-a-sep=".">
                                    @Html.HiddenFor(x => x.OriginalPrice, new { @class = "", @placeholder = "Giá nhập" })
                                    @Html.ValidationMessageFor(x => x.OriginalPrice, null, new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>

                        <div style="margin-bottom:30px; margin-top:10px" class="custom-control custom-checkbox">
                            @Html.CheckBoxFor(x => x.IsActive, new { @class = "custom-control-input", @id = "IsActiveCheckbox", @checked = "checked" })
                            @*<input class="custom-control-input" type="checkbox" id="customCheckbox2" checked="">*@
                            <label for="IsActiveCheckbox" class="custom-control-label">Hiển thị</label>
                        </div>

                        <div class="form-group">
                            <a href="/admin/productinventory" class="btn btn-danger">Quay lại</a>
                            <button type="submit" class="btn btn-primary">Thêm mới</button>
                        </div>
                    </div>

                }

            </div>
        </div>
        <!-- /.card-body -->
        <div class="card-footer">

        </div>
        <!-- /.card-footer-->
    </div>
    <!-- /.card -->

</section>
<!-- /.content -->

@section scripts{
        <script src="~/Scripts/autoNumeric-1.9.45.js"></script>

        <script>
            $(document).ready(function () {
                // Khởi tạo autoNumeric trên tất cả các input cần thiết
                $('.autoNum').autoNumeric('init', { aSep: ',', aDec: '.', mDec: '0' });

                // Khởi tạo autoNumeric cho các input ẩn
                $('#Price, #PriceSale, #Quantity, #OriginalPrice').autoNumeric('init', { aSep: ',', aDec: '.', mDec: '0' });

                // Giá
                $('#demoPrice').on('blur focusout keypress keyup', function () {
                    var demoGet = $(this).autoNumeric('get');
                    $('#Price').val(demoGet); // Gán giá trị thô
                });

                // Giá khuyến mãi
                $('#demoPriceSale').on('blur focusout keypress keyup', function () {
                    var demoGet = $(this).autoNumeric('get');
                    $('#PriceSale').val(demoGet); // Gán giá trị thô
                });

                // Số lượng sản phẩm
                $('#demoQuantity').on('blur focusout keypress keyup', function () {
                    var demoGet = $(this).autoNumeric('get');
                    $('#Quantity').val(demoGet); // Gán giá trị thô
                });

                // Giá nhập
                $('#demoOriginalPrice').on('blur focusout keypress keyup', function () {
                    var demoGet = $(this).autoNumeric('get');
                    $('#OriginalPrice').val(demoGet); // Gán giá trị thô
                });
            });
        </script>
    }

