@*@model WebBanHangOnline.Models.EF.Order*@
@model List<WebBanHangOnline.Models.EF.Order>

<div style="margin-bottom:10px">Số lượng đơn: @Model.Count()</div>
@foreach (var order in Model)
{
    <div class="order-info-box p-3 bg-light rounded mb-3">
        <h4 class="text-success text-center">Thông Tin Đơn Hàng</h4>
        <p><strong>Mã đơn hàng:</strong> @order.Code</p>
        <p>
            <strong>Trạng thái:</strong>
            @if (order.OrderStatus == 1)
            {
                <span class="status-badge status-unpaid">Chưa thanh toán</span>
            }
            @if (order.OrderStatus == 2)
            {
                <span class="status-badge status-paid">Đã thanh toán</span>
            }
            @if (order.OrderStatus == 3)
            {
                <span class="status-badge status-completed">Hoàn thành</span>
            }
            @if (order.OrderStatus == 4)
            {
                <span class="status-badge status-cancelled">Hủy</span>
            }
            @if (order.OrderStatus == 5)
            {
                <span class="status-badge status-delivering">Đang giao</span>
            }
            @if (order.OrderStatus == 6)
            {
                <span class="status-badge status-preparing">Đang chuẩn bị hàng</span>
            }
            @if (order.OrderStatus == 7)
            {
                <span class="status-badge status-unsuccessful">Giao hàng không thành công</span>
            }
        </p>
        <p><strong>Ngày đặt hàng:</strong> @order.CreatedDate.ToString("dd/MM/yyyy")</p>
        <p><strong>Tổng tiền:</strong> @order.TotalAmount.ToString("N0") đ</p>

        <h5>Chi tiết sản phẩm</h5>
        <ul>
            @foreach (var item in order.OrderDetails)
            {
                <li>
                    <img style="width:100px; height:100px; object-fit: contain" src="@item.ProductInventory.Product.ProductImage.FirstOrDefault(x=>x.IsDefault).Image" />
                    - @item.ProductInventory.Product.Title - Số lượng: @item.Quantity - Giá: @item.Price.ToString("N0") đ
                </li>
            }
        </ul>
    </div>
}

